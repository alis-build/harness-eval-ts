{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/alis-build/harness-eval-ts/main/schemas/eval-interchange.schema.json",
  "title": "EvalDatasetRow",
  "description": "Flattened row for trajectory projection JSONL.",
  "type": "object",
  "properties": {
    "caseId": {
      "$ref": "#/$defs/__schema0"
    },
    "repetitionIndex": {
      "$ref": "#/$defs/__schema1"
    },
    "prompt": {
      "$ref": "#/$defs/__schema2"
    },
    "response": {
      "$ref": "#/$defs/__schema4"
    },
    "evaluationInstance": {
      "$ref": "#/$defs/__schema6"
    },
    "latencySeconds": {
      "$ref": "#/$defs/__schema12"
    },
    "failure": {
      "$ref": "#/$defs/__schema13"
    },
    "humanRatings": {
      "$ref": "#/$defs/__schema16"
    }
  },
  "required": [
    "caseId",
    "repetitionIndex",
    "latencySeconds",
    "failure"
  ],
  "additionalProperties": false,
  "$defs": {
    "__schema0": {
      "type": "string",
      "description": "Test case id."
    },
    "__schema1": {
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991,
      "description": "Repetition index."
    },
    "__schema2": {
      "description": "Eval prompt sent to the agent.",
      "$ref": "#/$defs/__schema3"
    },
    "__schema3": {
      "type": "string"
    },
    "__schema4": {
      "description": "Final agent response text.",
      "$ref": "#/$defs/__schema5"
    },
    "__schema5": {
      "type": "string"
    },
    "__schema6": {
      "description": "Vertex EvaluationInstance wire object.",
      "$ref": "#/$defs/EvaluationInstanceJson"
    },
    "EvaluationInstanceJson": {
      "type": "object",
      "properties": {
        "prompt": {
          "$ref": "#/$defs/__schema7"
        },
        "response": {
          "$ref": "#/$defs/__schema10"
        },
        "reference": {
          "$ref": "#/$defs/__schema11"
        }
      },
      "additionalProperties": false,
      "title": "EvaluationInstanceJson",
      "description": "Vertex EvaluationInstance wire format (agentEvalData omitted in v1)."
    },
    "__schema7": {
      "description": "Eval prompt.",
      "$ref": "#/$defs/InstanceData"
    },
    "InstanceData": {
      "type": "object",
      "properties": {
        "text": {
          "$ref": "#/$defs/__schema8"
        }
      },
      "additionalProperties": false,
      "title": "InstanceData",
      "description": "EvaluationInstance prompt/response/reference text wrapper."
    },
    "__schema8": {
      "description": "Plain text instance data.",
      "$ref": "#/$defs/__schema9"
    },
    "__schema9": {
      "type": "string"
    },
    "__schema10": {
      "description": "Final agent response.",
      "$ref": "#/$defs/InstanceData"
    },
    "__schema11": {
      "description": "Reference answer text.",
      "$ref": "#/$defs/InstanceData"
    },
    "__schema12": {
      "type": "number",
      "description": "Session latency in seconds."
    },
    "__schema13": {
      "anyOf": [
        {
          "$ref": "#/$defs/__schema14"
        },
        {
          "$ref": "#/$defs/__schema15"
        }
      ],
      "description": "1 when the harness run failed, 0 on success."
    },
    "__schema14": {
      "type": "number",
      "const": 0
    },
    "__schema15": {
      "type": "number",
      "const": 1
    },
    "__schema16": {
      "description": "Human ratings keyed by metric name for judge calibration.",
      "$ref": "#/$defs/__schema17"
    },
    "__schema17": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "number"
      }
    }
  }
}
